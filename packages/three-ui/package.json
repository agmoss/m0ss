{
    "name": "three-ui",
    "version": "1.1.1",
    "description": "React UI Component Library",
    "keywords": [
        "ui",
        "library",
        "material"
    ],
    "homepage": "https://github.com/agmoss/m0ss#readme",
    "bugs": {
        "url": "https://github.com/agmoss/m0ss/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/agmoss/m0ss.git"
    },
    "license": "MIT",
    "author": "Andrew Moss <andrew@m0ss.dev>",
    "main": "dist/index.js",
    "module": "dist/index.es.js",
    "types": "dist/index.d.ts",
    "directories": {
        "test": "__tests__",
        "src": "src"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "rollup -c",
        "build:dev": "rollup -c",
        "format": "prettier --write \"src/**/*.tsx\"",
        "lint": "eslint --fix --ext .ts,.tsx .",
        "pkg-ok": "pkg-ok",
        "prepare": "yarn run build",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "dependencies": {
        "lodash-es": "^4.17.21",
        "react-color": "^2.19.3",
        "react-spring": "^9.2.3",
        "react-with-gesture": "^4.0.8"
    },
    "devDependencies": {
        "@types/react": "^17.0.14",
        "@typescript-eslint/eslint-plugin": "^4.28.2",
        "@typescript-eslint/parser": "^4.28.2",
        "eslint": "^7.30.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-import": "^2.23.4",
        "eslint-plugin-jsx-a11y": "^6.4.1",
        "eslint-plugin-prettier": "^3.4.0",
        "eslint-plugin-react": "^7.24.0",
        "eslint-plugin-react-hooks": "^4.2.0",
        "pkg-ok": "^2.3.1",
        "prettier": "^2.3.2",
        "rollup": "^2.53.1",
        "rollup-plugin-babel": "^4.4.0",
        "rollup-plugin-commonjs": "^10.1.0",
        "rollup-plugin-css-bundle": "^1.0.4",
        "rollup-plugin-css-only": "^3.1.0",
        "rollup-plugin-embed-css": "^1.0.21",
        "rollup-plugin-json": "^4.0.0",
        "rollup-plugin-node-resolve": "^5.2.0",
        "rollup-plugin-peer-deps-external": "^2.2.4",
        "rollup-plugin-postcss": "^4.0.0",
        "rollup-plugin-postcss-modules": "^2.0.2",
        "rollup-plugin-typescript2": "^0.30.0",
        "source-map-loader": "^3.0.0",
        "ts-loader": "^9.2.3",
        "typescript": "^4.3.5"
    },
    "peerDependencies": {
        "@material-ui/core": "^4.11.0",
        "@material-ui/icons": "^4.9.1",
        "react": "^16.13.1",
        "react-dom": "^16.13.1"
    },
    "engines": {
        "node": "14.X",
        "yarn": ">=1.19.1"
    }
}
